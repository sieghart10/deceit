{
  "manifest_version": 3,
  "name": "Fake News Detector",
  "version": "1.0.0",
  "description": "News detector that checks if news or posts are real or fake using TF-IDF and Naive Bayes.",
  
  "permissions": [
    "contextMenus",
    "storage",
    "tabs",
    "activeTab",
    "notifications",
    "scripting"

  ],
  
  "host_permissions": [
    "*://*.facebook.com/*",
    "http://127.0.0.1/*"

  ],
  
  "background": {
    "service_worker": "extension/scripts/background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["extension/scripts/content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],

  "icons": {
  "16": "extension/icons/detective-black.png",
  "48": "extension/icons/detective-black.png",
  "128": "extension/icons/detective-black.png"
  },
  
  "action": {
    "default_popup": "extension/html/popup.html",
    "default_title": "Fake News Detector",
    "default_icon": {
      "16": "extension/icons/detective-black.png",
      "48": "extension/icons/detective-black.png",
      "128": "extension/icons/detective-black.png"
    }
  },
  
  "web_accessible_resources": [
    {
      "resources": ["extension/styles/*.css"],
      "matches": ["*://*.facebook.com/*"]
    },
      {
    "resources": ["extension/html/upload.html"],
    "matches": ["<all_urls>"]
  }
  ]
}